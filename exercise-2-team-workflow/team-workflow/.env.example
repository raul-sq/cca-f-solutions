# Copy to .env (gitignored) and fill in real values.
# These feed the ${VAR} placeholders in .mcp.json via Claude Code env-var expansion.
# A ${VAR} with no default makes Claude Code FAIL TO PARSE .mcp.json if it is unset,
# so every required variable below must be exported before launching `claude`.

# GitHub MCP (http) - personal access token (required, no default)
GITHUB_TOKEN=

# Internal API MCP (http) - base URL has a default; token is required
INTERNAL_API_BASE_URL=https://api.internal.example.com
INTERNAL_API_TOKEN=

# Team Postgres MCP (stdio) - connection string (required, no default)
DATABASE_URL=postgresql://user:password@localhost:5432/teamdb
PGAPPNAME=claude-code
